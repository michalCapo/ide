#!/usr/bin/env bash
set -euo pipefail

file=${1:?missing filename}
line=${2:-1}
col=${3:-0}
file=$(realpath -m -- "$file")

[[ $line =~ ^[0-9]+$ ]] || line=1
[[ $col =~ ^[0-9]+$ ]] || col=0

if [[ -z ${LAZYGIT_NVIM_EDIT_REQUEST:-} ]]; then
  exec nvim "+call cursor($line,$((col + 1)))" -- "$file"
fi

printf '%s\n%s\n%s\n' "$file" "$line" "$col" > "$LAZYGIT_NVIM_EDIT_REQUEST"

# The parent Neovim reads the request from its normal terminal on_exit callback.
# No RPC is used here, so neither side can wait synchronously on the other.
pid=$PPID
while [[ $pid =~ ^[0-9]+$ && $pid -gt 1 ]]; do
  command=$(ps -o comm= -p "$pid" 2>/dev/null || true)
  command=${command//[[:space:]]/}
  if [[ $command == lazygit ]]; then
    kill -TERM "$pid"
    exit 0
  fi

  pid=$(ps -o ppid= -p "$pid" 2>/dev/null || true)
  pid=${pid//[[:space:]]/}
done

echo "nvim-edit-parent: could not find the Lazygit process" >&2
exit 1
